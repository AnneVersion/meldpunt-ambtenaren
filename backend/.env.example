# Meldpunt Ambtenaren — Environment Variables
# Kopieer naar .env en vul de waarden in

MELDPUNT_SECRET_KEY=vul_hier_een_random_string_in
MELDPUNT_DB_HOST=localhost
MELDPUNT_DB_PORT=5432
MELDPUNT_DB_NAME=meldpunt
MELDPUNT_DB_USER=meldpunt
MELDPUNT_DB_PASS=vul_hier_db_wachtwoord_in
MELDPUNT_ADMIN_USER=admin
MELDPUNT_ADMIN_PASS=vul_hier_admin_wachtwoord_in
MELDPUNT_HTTPS=true
DATABASE_URL=postgresql://meldpunt:vul_hier_db_wachtwoord_in@localhost:5432/meldpunt
